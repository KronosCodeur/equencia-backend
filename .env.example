# ─────────────────────────────────────────────────────────────
#  Equencia Backend — Variables d'Environnement
#
#  USAGE :
#  1. cp .env.example .env
#  2. Modifier les valeurs marquées REQUIRED
#  3. Ne jamais committer .env dans Git
# ─────────────────────────────────────────────────────────────

# ── Environnement ─────────────────────────────────────────────
APP_ENV=dev
# Valeurs : dev | test | prod

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=equencia
POSTGRES_USER=equencia
POSTGRES_PASSWORD=equencia_secret           # REQUIRED en prod

# URL pour chaque service Symfony
AUTH_DATABASE_URL=postgresql://equencia:equencia_secret@postgres:5432/equencia?serverVersion=16&charset=utf8
RH_DATABASE_URL=postgresql://equencia:equencia_secret@postgres:5432/equencia?serverVersion=16&charset=utf8
OPS_DATABASE_URL=postgresql://equencia:equencia_secret@postgres:5432/equencia?serverVersion=16&charset=utf8

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret                 # REQUIRED en prod
REDIS_URL=redis://:redis_secret@redis:6379

# Namespacing par service (évite les collisions)
AUTH_REDIS_PREFIX=auth:
RH_REDIS_PREFIX=rh:
OPS_REDIS_PREFIX=ops:

# Streams Messenger
AUTH_REDIS_STREAM=auth_messages
RH_REDIS_STREAM=rh_messages
OPS_REDIS_STREAM=ops_messages

# ── JWT — Auth Service ────────────────────────────────────────
# Générer avec : make jwt-keys
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=                             # Laisser vide si clé sans passphrase
JWT_TOKEN_TTL=900                           # 15 minutes (secondes)
JWT_REFRESH_TOKEN_TTL=604800               # 7 jours (secondes)

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
# En prod : '^https://equencia\.app$'

# ── Mercure (SSE) ─────────────────────────────────────────────
MERCURE_URL=http://mercure:3001/.well-known/mercure
MERCURE_JWT_SECRET=mercure_dev_secret       # REQUIRED en prod — min 32 chars
MERCURE_PUBLIC_URL=http://localhost:3001/.well-known/mercure

# ── MinIO (S3 Object Storage) ─────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio_admin               # REQUIRED en prod
MINIO_SECRET_KEY=minio_secret_key          # REQUIRED en prod — min 16 chars
MINIO_BUCKET=equencia-uploads
MINIO_REGION=us-east-1                     # Valeur par défaut MinIO

# ── Gotenberg (PDF) ───────────────────────────────────────────
GOTENBERG_URL=http://gotenberg:3000

# ── Email ─────────────────────────────────────────────────────
# Dev : MailHog (http://localhost:8025)
MAILER_DSN=smtp://mailhog:1025
# Prod exemple : smtp://user:pass@smtp.sendgrid.net:587

MAIL_FROM=noreply@equencia.app
MAIL_FROM_NAME=Equencia

# ── WhatsApp (Notifications) ──────────────────────────────────
WHATSAPP_API_TOKEN=                         # Meta Business API token
WHATSAPP_PHONE_NUMBER_ID=                   # Phone Number ID

# ── FCM (Push mobile — Phase 2) ───────────────────────────────
FCM_SERVER_KEY=                             # Firebase Cloud Messaging

# ── FedaPay (Paiement Afrique de l'Ouest) ────────────────────
FEDAPAY_API_KEY=                            # REQUIRED pour billing
FEDAPAY_WEBHOOK_SECRET=                     # Pour valider les webhooks
FEDAPAY_ENV=sandbox                         # sandbox | live

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug
# Valeurs : debug | info | notice | warning | error | critical

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_LOGIN=10                         # 10 req / 15 min par IP
RATE_LIMIT_REGISTER=3                       # 3 req / 1h par IP
RATE_LIMIT_API=2000                         # 2000 req / min par tenant
